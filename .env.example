# ============================================================
# Cardnews Skill — 환경 변수
#
# 사용:
#   cp .env.example .env
#   그 후 .env 파일의 값을 실제 값으로 교체
#
# ⚠️ .env 파일은 .gitignore 에 포함되어 있습니다 (절대 커밋 금지)
# ============================================================

# --- Instagram Graph API ---
# Instagram Business/Creator 계정 ID (Graph API Explorer 로 조회)
IG_USER_ID=

# Long-lived Access Token (60일 유효)
# 권한 필수: instagram_basic, instagram_content_publish, pages_show_list, pages_read_engagement
IG_ACCESS_TOKEN=

# --- 이미지 호스팅 ---
# 옵션 A: Imgur 익명 업로드 (간편, 무료)
#   https://api.imgur.com/oauth2/addclient 에서 Client ID 발급 (OAuth 2 authorization, anonymous usage)
IMGUR_CLIENT_ID=

# 옵션 B: 직접 호스팅 URL 사용 (IMGUR_CLIENT_ID 대체)
#   <base>/card-01.png, card-02.png ... 형태로 접근 가능해야 함
# IMAGE_BASE_URL=https://cdn.example.com/cards/20260421_example
